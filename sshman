def get_host(hosts, alias):
    for h in hosts:
        if h['Host'].lower() == alias.lower():
            return h
    return None

# ----------------------------------------------------------------
# Common helpers (extracted to avoid duplication)
# ----------------------------------------------------------------
def get_real_hosts():
    """Parse config and return hosts excluding the wildcard Host *."""
    hosts, _ = parse_config()
    return [h for h in hosts if h['Host'] != '*']

def resolve_alias(hosts, alias_arg, prompt_str):
    """Return alias from args or fzf selection. Exits if no hosts or none selected."""
    if not hosts:
        warn("No hay hosts configurados.")
        sys.exit(0)
    if alias_arg:
        return alias_arg
    selected = fzf_select([h['Host'] for h in hosts], prompt_str=prompt_str)
    if not selected:
        sys.exit(0)
    return selected

def require_host(hosts, alias):
    """Find host by alias; print error and exit if not found."""
    h = get_host(hosts, alias)
    if not h:
        err(f"No encontrado: '{alias}'")
        sys.exit(1)
    return h

def display_host(host):
    """Print formatted details of a host entry."""
    print(f"\n{C.BOLD}  {host['Host']}{C.RESET}")
    print(f"  HostName     {host.get('hostname','')}")
    print(f"  User         {host.get('user','')}")
    if 'port' in host:
        print(f"  Port         {host['port']}")
    if 'identityfile' in host:
        print(f"  IdentityFile {host['identityfile']}")
    if 'proxyjump' in host:
        print(f"  ProxyJump    {host['proxyjump']}")
    if 'proxycommand' in host:
        print(f"  ProxyCommand {host['proxycommand']}")
    if 'identitiesonly' in host:
        print(f"  IdentitiesOnly {host['identitiesonly']}")
    print()

# ----------------------------------------------------------------
# Terminal background color helpers
# ----------------------------------------------------------------
def set_terminal_bg(color_hex):
    """Set terminal background color via OSC 11 sequence."""
    sys.stdout.write(f"\033]11;{color_hex}\007")
    sys.stdout.flush()

def reset_terminal_bg():
    """Reset terminal background to default via OSC 11 sequence."""
    sys.stdout.write("\033]11;default\007")
    sys.stdout.flush()

def terminal_bg_for_alias(alias):
    """Return a background color hex string based on the alias name."""
    a = alias.lower()
    if 'prod' in a:
        return '#CC0000'      # Red for production
    if 'test' in a or 'staging' in a or 'dr' in a:
        return '#FF8800'      # Orange for test/staging/DR
    if 'dev' in a or 'lab' in a:
        return '#008800'      # Green for dev/lab
    if 'bastion' in a:
        return '#CCCC00'      # Yellow for bastions
    return '#0066CC'          # Blue default

# ----------------------------------------------------------------
# fzf helper
# ----------------------------------------------------------------
def fzf_select(items, prompt_str="", preview_cmd=None):
    if not shutil.which('fzf'):
        err("fzf no encontrado. Instala con: brew install fzf")
        sys.exit(1)
    cmd = ['fzf', f'--prompt={prompt_str}', '--height=50%', '--border',
           '--ansi', '--tac']
    if preview_cmd:
        cmd += ['--preview', preview_cmd]
    result = subprocess.run(cmd, input='\n'.join(items), text=True,
                            capture_output=True)
    return result.stdout.strip() or None

# ----------------------------------------------------------------
# Prompt helper
# ----------------------------------------------------------------
def prompt(label, default=None, required=False):
    hint = f" [{default}]" if default else ""
    while True:
        val = input(f"  {label}{hint}: ").strip()
        if not val and default is not None:
            return default
        if not val and required:
            warn("  Campo obligatorio.")
            continue
        return val or None

# ----------------------------------------------------------------
# -add
# ----------------------------------------------------------------
def cmd_add(args):
    hosts, preamble = parse_config()

    if args.alias and args.host and args.user:
        alias    = args.alias
        hostname = args.host
        user     = args.user
        port     = args.port
        key      = args.key
        jump     = args.jump
        jump_key = args.jump_key
    else:
        info("\n── Agregar nueva conexión ──────────────────────────\n")
        alias    = prompt("Alias  (ej: ucuenca-prod-nuevo)", required=True)
        hostname = prompt("Hostname / IP", required=True)
        user     = prompt("Usuario", required=True)
        port     = prompt("Puerto", default="22")
        key      = prompt("Ruta llave .pem  (vacío si no aplica)")
        if key:
            key = os.path.expanduser(key)
        jump     = prompt("Jump server  usuario@host:puerto  (vacío si no aplica)")
        jump_key = None
        if jump:
            jk = prompt("  Ruta llave jump .pem  (vacío si misma llave)")
            jump_key = os.path.expanduser(jk) if jk else None

    if get_host(hosts, alias):
        err(f"El alias '{alias}' ya existe. Usa -edit para modificarlo.")
        sys.exit(1)

    # Validate port if given
    if port:
        try:
            port_int = int(port)
            if port_int < 1 or port_int > 65535:
                err(f"Puerto inválido: {port}")
                sys.exit(1)
        except ValueError:
            err(f"Puerto no es un número: {port}")
            sys.exit(1)

    new = {'Host': alias, '_extra': [], 'hostname': hostname, 'user': user}
    if port and port != '22':
        new['port'] = port
    if key:
        new['identityfile'] = key
    if jump:
        if jump_key:
            jhost, jport = (jump.rsplit(':', 1) if ':' in jump else (jump, '22'))
            new['proxycommand'] = f"ssh -W %h:%p -i {jump_key} {jhost} -p {jport}"
        else:
            new['proxyjump'] = jump

    # Insertar junto al mismo cliente
    client = alias.split('-')[0].lower()
    insert_at = len(hosts)
    for i, h in enumerate(hosts):
        if h['Host'] == '*':
            continue
        if h['Host'].lower().startswith(client):
            insert_at = i + 1

    hosts.insert(insert_at, new)
    write_config(hosts, preamble)
    ok(f"'{alias}'  →  {user}@{hostname}" + (f"  (jump: {jump})" if jump else ""))

# ----------------------------------------------------------------
# -list
# ----------------------------------------------------------------
def cmd_list(args):
    real = get_real_hosts()

    if not real:
        warn("No hay hosts configurados.")
        return

    if args.plain:
        # Non-interactive: print all hosts in a table
        print(f"\n{'Cliente':<14} {'Alias':<42} {'User@Host':<30} {'Jump':<30}")
        print("─" * 116)
        for h in real:
            jump = ''
            if 'proxyjump' in h:
                jump = h['proxyjump']
            elif 'proxycommand' in h:
                for part in h['proxycommand'].split():
                    if '@' in part and not part.startswith('-'):
                        jump = part
                        break
            client = h['Host'].split('-')[0].upper()
            hostname = h.get('hostname', '?')
            user = h.get('user', '?')
            print(f"{client:<14} {h['Host']:<42} {user}@{hostname:<28} {jump}")
        print()
        return

    # Interactive fzf mode
    lines = []
    for h in real:
        jump = ''
        if 'proxyjump' in h:
            jump = h['proxyjump']
        elif 'proxycommand' in h:
            for part in h['proxycommand'].split():
                if '@' in part and not part.startswith('-'):
                    jump = part
                    break
        client = h['Host'].split('-')[0].upper()
        col1 = h['Host']
        col2 = f"{h.get('user','?')}@{h.get('hostname','?')}"
        col3 = f"→ {jump}" if jump else ''
        lines.append(f"{C.CYAN}{client:<12}{C.RESET} {col1:<45} {col2:<35} {C.DIM}{col3}{C.RESET}")

    # Preview: fzf replaces {} with selected line. xargs uses % to avoid conflict.
    preview = "echo {} | sed 's/\\x1b\\[[0-9;]*m//g' | awk '{print $2}' | xargs -I% sh -c 'grep -A10 \"^Host %$\" ~/.ssh/config 2>/dev/null || echo \"(sin detalles)\"'"
    selected = fzf_select(lines, prompt_str="Host> ", preview_cmd=preview)
    if not selected:
        return

    # Extract alias by stripping ANSI and taking second token
    clean = re.sub(r'\033\[[0-9;]*m', '', selected).strip()
    parts = clean.split()
    if len(parts) < 2:
        err("No se pudo extraer el alias de la selección.")
        return
    alias = parts[1]
    h = get_host(real, alias)
    if not h:
        err(f"No encontrado: '{alias}'")
        return
    display_host(h)

# ----------------------------------------------------------------
# -connect
# ----------------------------------------------------------------
def cmd_connect(args):
    real = get_real_hosts()
    alias = resolve_alias(real, args.alias, "Conectar a> ")
    h = require_host(real, alias)
    print(f"\n{C.BOLD}Conectando a {alias}...{C.RESET}")

    if sys.stdout.isatty():
        set_terminal_bg(terminal_bg_for_alias(alias))
        try:
            subprocess.run(['ssh', alias])
        finally:
            reset_terminal_bg()
    else:
        subprocess.run(['ssh', alias])

# ----------------------------------------------------------------
# -show
# ----------------------------------------------------------------
def cmd_show(args):
    if not args.alias:
        err("-show requiere -alias")
        sys.exit(1)
    real = get_real_hosts()
    h = require_host(real, args.alias)
    display_host(h)

# ----------------------------------------------------------------
# -test
# ----------------------------------------------------------------
def cmd_test(args):
    real = get_real_hosts()
    alias = resolve_alias(real, args.alias, "Testear> ")
    h = require_host(real, alias)

    print(f"\n{C.BOLD}Probando configuración para {alias}...{C.RESET}")
    try:
        result = subprocess.run(
            ['ssh', '-G', alias],
            capture_output=True, text=True, timeout=10
        )
        if result.returncode == 0:
            ok("ssh -G pasó correctamente")
            # Show resolved config
            print()
            for line in result.stdout.strip().split('\n'):
                parts = line.split(None, 1)
                if len(parts) == 2:
                    key, val = parts
                    if key in ('hostname', 'user', 'port', 'identityfile',
                               'proxycommand', 'proxyjump', 'stricthostkeychecking'):
                        print(f"  {key:<25} {val}")
        else:
            err("ssh -G falló:")
            if result.stderr:
                print(f"  {result.stderr.strip()}")
            sys.exit(1)
    except subprocess.TimeoutExpired:
        err("ssh -G timeout (10s)")
        sys.exit(1)
    except FileNotFoundError:
        err("ssh no encontrado en PATH")
        sys.exit(1)
    print()

# ----------------------------------------------------------------
# -remove
# ----------------------------------------------------------------
def cmd_remove(args):
    hosts, preamble = parse_config()
    real = [h for h in hosts if h['Host'] != '*']

    alias = resolve_alias(real, args.alias, "Eliminar> ")
    host = require_host(real, alias)

    print(f"\n  {C.BOLD}{alias}{C.RESET}  →  "
          f"{host.get('user','?')}@{host.get('hostname','?')}")
    confirm = input("  ¿Confirmar eliminación? [s/N]: ").strip().lower()
    if confirm != 's':
        warn("Cancelado.")
        return

    hosts = [h for h in hosts if h['Host'] != alias]
    write_config(hosts, preamble)
    ok(f"'{alias}' eliminado.")

# ----------------------------------------------------------------
# -edit
# ----------------------------------------------------------------
def cmd_edit(args):
    hosts, preamble = parse_config()
    real = [h for h in hosts if h['Host'] != '*']

    alias = resolve_alias(real, args.alias, "Editar> ")
    host = require_host(real, alias)

    info(f"\n── Editando: {alias} ──────────────────────────────")
    info("  (Enter para mantener el valor actual)\n")

    host['hostname'] = prompt("Hostname / IP", default=host.get('hostname')) or host['hostname']
    host['user']     = prompt("Usuario", default=host.get('user')) or host['user']

    new_port = prompt("Puerto", default=host.get('port', '22'))
    if new_port and new_port != '22':
        try:
            port_int = int(new_port)
            if port_int < 1 or port_int > 65535:
                err(f"Puerto inválido: {new_port}")
                sys.exit(1)
        except ValueError:
            err(f"Puerto no es un número: {new_port}")
            sys.exit(1)
        host['port'] = new_port
    else:
        host.pop('port', None)

    new_key = prompt("Ruta llave .pem", default=host.get('identityfile', ''))
    if new_key:
        host['identityfile'] = os.path.expanduser(new_key)
    elif 'identityfile' in host:
        remove_key = input("  ¿Quitar la llave actual? [s/N]: ").strip().lower()
        if remove_key == 's':
            host.pop('identityfile', None)

    # Edit ProxyJump/ProxyCommand
    current_jump = host.get('proxyjump', '')
    current_pc = host.get('proxycommand', '')
    has_jump = bool(current_jump or current_pc)

    if has_jump:
        jump_display = current_jump or current_pc
        info(f"\n  Jump actual: {jump_display}")
        new_jump = prompt("Nuevo jump (usuario@host:puerto / 'quitar' / Enter para mantener)",
                          default=None)
    else:
        new_jump = prompt("Agregar jump server (usuario@host:puerto / Enter para omitir)",
                          default=None)

    if new_jump and new_jump.strip():
        j_input = new_jump.strip()
        if j_input.lower() == 'quitar':
            host.pop('proxyjump', None)
            host.pop('proxycommand', None)
        elif '@' in j_input:
            # Parse user@host:port
            if ':' in j_input:
                j_host_port = j_input.rsplit(':', 1)
                j_host = j_host_port[0]
                j_port = j_host_port[1]
            else:
                j_host = j_input
                j_port = '22'
            new_key_input = prompt("  Ruta llave jump .pem  (vacío si misma llave)")
            if new_key_input:
                nk = os.path.expanduser(new_key_input.strip())
                host['proxycommand'] = f"ssh -W %h:%p -i {nk} {j_host} -p {j_port}"
            else:
                host['proxycommand'] = f"ssh -W %h:%p {j_host} -p {j_port}"
            host.pop('proxyjump', None)
        else:
            warn("Formato de jump inválido. Use usuario@host:puerto")

    # Edit IdentitiesOnly
    current_io = host.get('identitiesonly', '')
    if current_io:
        new_io = prompt("IdentitiesOnly (yes/no/quitar / Enter para mantener)",
                        default=None)
    else:
        new_io = prompt("IdentitiesOnly (yes/no / Enter para omitir)",
                        default=None)
    if new_io and new_io.strip():
        val = new_io.strip().lower()
        if val == 'quitar':
            host.pop('identitiesonly', None)
        elif val in ('yes', 'no'):
            host['identitiesonly'] = val

    write_config(hosts, preamble)
    ok(f"'{alias}' actualizado.")

