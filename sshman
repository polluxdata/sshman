def parse_config():
    """Parse ~/.ssh/config preserving all options and line structure."""
    hosts    = []
    current  = None
    preamble = []

    if not SSH_CONFIG.exists():
        return [], []

    with open(SSH_CONFIG) as f:
        for line in f:
            stripped = line.strip()
            if not stripped or stripped.startswith('#'):
                if current is None:
                    preamble.append(line)
                continue
            m = re.match(r'^Host\s+(.+)$', stripped, re.IGNORECASE)
            if m:
                if current:
                    hosts.append(current)
                current = {'Host': m.group(1).strip(), '_extra': []}
            elif current is not None:
                m2 = re.match(r'^(\S+)\s+(.+)$', stripped)
                if m2:
                    key = m2.group(1).lower()
                    val = m2.group(2).strip()
                    if key in KNOWN_SSH_OPTIONS:
                        current[key] = val
                    else:
                        current['_extra'].append(line)
                else:
                    current['_extra'].append(line)
        if current:
            hosts.append(current)

    return hosts, preamble

