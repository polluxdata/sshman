def main():
    parser = argparse.ArgumentParser(
        prog='sshman',
        description='Gestor de conexiones SSH — PolluxData',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Ejemplos:
  sshman -list
  sshman -list --plain
  sshman -connect
  sshman -connect -alias polluxdata-sites
  sshman -add
  sshman -add -alias yoveri-oci-nuevo -host 172.19.1.200 -user opc
  sshman -add -alias yoveri-oci-nuevo -host 172.19.1.200 -user opc \\
         -key ~/.ssh/keys/YOVERI/OCI-BTA/nuevo.pem \\
         -jump opc@149.130.180.28:22
  sshman -remove
  sshman -remove -alias yoveri-oci-nuevo
  sshman -edit
  sshman -edit -alias yoveri-oci-nuevo
  sshman -show -alias polluxdata-sites
  sshman -test -alias polluxdata-sites
        """
    )

    mode = parser.add_mutually_exclusive_group(required=True)
    mode.add_argument('-add',     action='store_true')
    mode.add_argument('-list',    action='store_true')
    mode.add_argument('-remove',  action='store_true')
    mode.add_argument('-edit',    action='store_true')
    mode.add_argument('-connect', action='store_true')
    mode.add_argument('-show',    action='store_true')
    mode.add_argument('-test',    action='store_true')

    parser.add_argument('-alias',    help='Alias del host')
    parser.add_argument('-host',     help='Hostname o IP')
    parser.add_argument('-user',     help='Usuario SSH')
    parser.add_argument('-port',     help='Puerto (default: 22)')
    parser.add_argument('-key',      help='Ruta llave .pem')
    parser.add_argument('-jump',     help='Jump server usuario@host:puerto')
    parser.add_argument('-jump-key', dest='jump_key', help='Llave del jump server .pem')
    parser.add_argument('--plain',   action='store_true', help='Modo no interactivo para -list')

    args = parser.parse_args()

    if   args.add:     cmd_add(args)
    elif args.list:    cmd_list(args)
    elif args.remove:  cmd_remove(args)
    elif args.edit:    cmd_edit(args)
    elif args.connect: cmd_connect(args)
    elif args.show:    cmd_show(args)
    elif args.test:    cmd_test(args)

if __name__ == '__main__':
    main()
