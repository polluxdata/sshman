# ----------------------------------------------------------------
# Colores ANSI
# ----------------------------------------------------------------
class C:
    RED    = "\033[31m"
    GREEN  = "\033[32m"
    YELLOW = "\033[33m"
    CYAN   = "\033[36m"
    BOLD   = "\033[1m"
    DIM    = "\033[2m"
    RESET  = "\033[0m"

def ok(msg):   print(f"{C.GREEN}[OK]{C.RESET}  {msg}")
def err(msg):  print(f"{C.RED}[ERR]{C.RESET} {msg}", file=sys.stderr)
def warn(msg): print(f"{C.YELLOW}[WARN]{C.RESET} {msg}")
def info(msg): print(f"{C.CYAN}{msg}{C.RESET}")

# ----------------------------------------------------------------
# Backup
# ----------------------------------------------------------------
def backup_config():
    BACKUP_DIR.mkdir(parents=True, exist_ok=True)
    ts  = datetime.now().strftime("%Y%m%d_%H%M%S")
    dst = BACKUP_DIR / f"config.bak.{ts}"
    shutil.copy2(SSH_CONFIG, dst)
    return dst

